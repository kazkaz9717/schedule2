<div class="container mt-4" style="max-width: 500px;">
  <h1 class="mb-4">スケジュール新規作成</h1>

  <%= render "error_messages", object: @schedule_event %>

  <%= form_with model: @schedule_event do |f| %>
    <div class="mb-3">
      <%= f.label :title, "タイトル", class: "form-label" %>
      <%= f.text_field :title, class: "form-control" %>
    </div>

    <div class="row mb-3">
      <div class="col-6">
        <%= f.label :start_at, "開始日", class: "form-label" %>
        <%= f.date_field :start_at, class: "form-control" %>
      </div>

      <div class="col-6">
        <%= f.label :end_at, "終了日", class: "form-label" %>
        <%= f.date_field :end_at, class: "form-control" %>
      </div>
    </div>

    <div class="mb-3 form-check">
      <%= f.check_box :all_day, class: "form-check-input" %>
      <%= f.label :all_day, "終日の場合はチェック", class: "form-check-label" %>
    </div>



    <div class="mb-3">
      <%= f.label :memo, "メモ", class: "form-label" %>
      <%= f.text_area :memo, class: "form-control" %>
    </div>

    <div>
      <%= f.submit "登録する", class: "btn btn-primary" %>
      <%= link_to "一覧に戻る", schedule_events_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>