<div class="container mt-4" style="max-width: 1000px;">
  <h1 class="mb-4">スケジュール詳細</h1>

  <table class="table table-bordered">

    <tr>
      <th class="table-secondary" style="width: 20%">タイトル</th>
      <td><%= @schedule_event.title %></td>
    </tr>

    <tr>
      <th class="table-secondary">開始日</th>
      <td><%= @schedule_event.start_at.strftime("%Y/%m/%d") %></td>
    </tr>

    <tr>
      <th class="table-secondary">終了日</th>
      <td><%= @schedule_event.end_at.strftime("%Y/%m/%d") %></td>
    </tr>

    <tr>
      <th class="table-secondary">終日</th>
      <td><%= @schedule_event.all_day? ? "〇" : "" %></td>
    </tr>

    <tr>
      <th class="table-secondary">メモ</th>
      <td><%= @schedule_event.memo %></td>
    </tr>

    <tr>
      <th class="table-secondary">更新日時</th>
      <td><%= @schedule_event.updated_at.strftime("%Y/%m/%d %H:%M") %></td>
    </tr>

  </table>

  <div class="mt-3">
    <%= link_to "編集", edit_schedule_event_path(@schedule_event), class: "btn btn-warning" %>
    <%= link_to "一覧に戻る", schedule_events_path, class: "btn btn-secondary" %>
  </div>
</div>